    }
    {
      name: "field"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "geometry"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "record_timestamp"
      req: false
      type: "`$STRING`"
    }
    {
      name: "recordid"
      req: false
      type: "`$STRING`"
    }
  ]

  name: "download"
  op: {
    list: {
      name: "list"
      points: [
        {
          args: {
            query: [
              {
                example: "global-shark-attack"
                kind: "query"
