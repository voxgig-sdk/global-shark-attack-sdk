              }
            ]
          }
          method: "GET"
          orig: "/download"
          parts: [
            "download"
          ]
          select: {
            exist: [
              "dataset"
              "format"
              "refine_country"
              "refine_type"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
